OS=$(grep '^ID=' /etc/os-release | cut -d'=' -f2 | tr -d '" ' | cut -c 1-25) KERNEL=$(uname -r | cut -c 1-20) RAM=$(free -m | awk '/Mem:/ {printf "%.1fG/%.1fG", $3/1024, $2/1024}') ORANGE='\033[38;5;208m' MAGENTA='\033[0;35m' BLUE='\033[0;34m' BW='\033[1;37m' NC='\033[0m' RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[0;33m' CYAN='\033[0;36m' GREY='\033[38;5;244m'; printf "\n              ${RED}<${BLUE}$USER${RED}>${ORANGE}-${YELLOW}M${ORANGE}-${RED}<${BLUE}$HOSTNAME${RED}>${NC} \n ${MAGENTA}.--------------------------------------------------.${NC} \n ${MAGENTA}|${GREY} (${NC}o${YELLOW}_${NC}  ${GREY}(${NC}o${YELLOW}_${NC}  ${MAGENTA}|${BLUE} 蟀粈 ${MAGENTA}| ${BLUE}OS:     ${CYAN}%-25s${MAGENTA}| \n ${MAGENTA}|${GREY} //\  //\  ${MAGENTA}|${BLUE} 蟀將 ${MAGENTA}| ${BLUE}Kernel: ${CYAN}%-25s${MAGENTA}| \n ${MAGENTA}|${GREY} V_/_ V_/_ ${MAGENTA}|${BLUE} 蟀崨 ${MAGENTA}| ${BLUE}Memory: ${CYAN}%-25s${MAGENTA}| \n ${MAGENTA}'--------------------------------------------------'${NC} \n    ${RED}<---->${GREEN}<---->${YELLOW}<---->${BLUE}<---->${MAGENTA}<---->${CYAN}<---->${BW}<---->${NC} \n \n" "$OS" "$KERNEL" "$RAM"
